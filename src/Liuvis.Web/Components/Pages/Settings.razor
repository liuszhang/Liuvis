@page "/settings"
@rendermode @(new InteractiveServerRenderMode(prerender: true))
@inject ISettingsService SettingsService
@inject IObjectStorageService Storage
@inject IJSRuntime JS
@inject ILogger<Settings> Logger

<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudText Typo="Typo.h4" Class="pa-4">Settings</MudText>

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mx-4" />
}

<MudTabs Elevation="0" Class="px-4">
    <MudTabPanel Text="LLM Configuration">
        <MudCard Elevation="0" Class="mt-4">
            <MudCardContent>
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:16px">
                    <MudText Typo="Typo.h6">AI Language Model Providers</MudText>
                    @if (_activeProvider is not null)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                            Active: @_activeProvider.Name
                        </MudChip>
                    }
                </div>

                @* --- Provider List --- *@
                <MudTable Items="_providers" Hover="true" Dense="true" Elevation="0"
                    Loading="_isLoadingProviders" Striped="true">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Provider</MudTh>
                        <MudTh>Model</MudTh>
                        <MudTh>Base URL</MudTh>
                        <MudTh Style="text-align:right">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Name">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                @if (context.IsActive)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                }
                                <MudText>@context.Name</MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Provider">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                @context.Provider
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Model">@(context.Provider == "ollama" ? context.OllamaModel : context.Model)</MudTd>
                        <MudTd DataLabel="Base URL">
                            @(context.Provider == "ollama" ? context.OllamaUrl : context.BaseUrl)
                        </MudTd>
                        <MudTd Style="text-align:right">
                            <MudButtonGroup Size="Size.Small" Variant="Variant.Text">
                                @if (!context.IsActive)
                                {
                                    <MudButton Color="Color.Primary" OnClick="@(() => ActivateProviderAsync(context))"
                                        StartIcon="@Icons.Material.Filled.PlayArrow">Activate</MudButton>
                                }
                                <MudButton Color="Color.Default" OnClick="@(() => EditProviderAsync(context))"
                                    StartIcon="@Icons.Material.Filled.Edit">Edit</MudButton>
                                <MudButton Color="Color.Error" OnClick="@(() => DeleteProviderAsync(context))"
                                    StartIcon="@Icons.Material.Filled.Delete">Delete</MudButton>
                            </MudButtonGroup>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4 mud-text-secondary">No providers configured. Click "Add Provider" to get started.</MudText>
                    </NoRecordsContent>
                </MudTable>

                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mt-4"
                    OnClick="AddProviderAsync" StartIcon="@Icons.Material.Filled.Add">
                    Add Provider
                </MudButton>
            </MudCardContent>
        </MudCard>

        @* --- Edit / Add Dialog --- *@
        @if (_editDialogOpen)
        {
            <MudCard Elevation="2" Class="mt-4">
                <MudCardContent>
                    <MudText Typo="Typo.h6" Class="mb-4">
                        @(_editingProvider.Id == 0 ? "Add New Provider" : $"Edit: {_editingProvider.Name}")
                    </MudText>

                    <MudStack Spacing="4">
                        <MudTextField @bind-Value="_editingProvider.Name" Label="Name"
                            HelperText="A descriptive name for this provider"
                            Variant="Variant.Outlined" Required="true" />

                        <div>
                            <MudText Typo="Typo.subtitle2" Class="mb-2 mud-text-secondary">Connection Mode</MudText>
                            <MudToggleGroup @bind-Value="_editingProvider.Provider" T="string"
                                SelectionMode="SelectionMode.SingleSelection">
                                <MudToggleItem T="string" Value="@("ollama")">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.Computer" Size="Size.Small" />
                                        <MudText>Local Ollama</MudText>
                                    </MudStack>
                                </MudToggleItem>
                                <MudToggleItem T="string" Value="@("openai")">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.Cloud" Size="Size.Small" />
                                        <MudText>Custom API Key</MudText>
                                    </MudStack>
                                </MudToggleItem>
                            </MudToggleGroup>
                        </div>

                        @if (_editingProvider.Provider == "ollama")
                        {
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="8">
                                    <MudTextField @bind-Value="_editingProvider.OllamaUrl" Label="URL"
                                        HelperText="e.g. http://localhost:11434" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="_editingProvider.OllamaModel" Label="Model"
                                        HelperText="e.g. qwen3:4b" Variant="Variant.Outlined" />
                                </MudItem>
                            </MudGrid>
                        }
                        else
                        {
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="_editingProvider.ApiKey" Label="API Key"
                                        HelperText="sk-..." Variant="Variant.Outlined"
                                        InputType="@(_showEditApiKey ? InputType.Text : InputType.Password)"
                                        Adornment="Adornment.End"
                                        AdornmentIcon="@(_showEditApiKey ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                        OnAdornmentClick="() => _showEditApiKey = !_showEditApiKey" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="_editingProvider.BaseUrl" Label="Base URL"
                                        HelperText="e.g. https://api.deepseek.com" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="_editingProvider.Model" Label="Model"
                                        HelperText="e.g. deepseek-v4-pro" Variant="Variant.Outlined" />
                                </MudItem>
                            </MudGrid>
                        }

                        <MudDivider />

                        <MudText Typo="Typo.subtitle2" Class="mb-2 mud-text-secondary">Generation Parameters</MudText>
                        <MudGrid Spacing="3">
                            <MudItem xs="6" md="3">
                                <MudNumericField @bind-Value="_editingProvider.MaxTokens" Label="Max Tokens"
                                    Variant="Variant.Outlined" Min="100" Max="32000" Step="100" />
                            </MudItem>
                            <MudItem xs="6" md="3">
                                <MudNumericField @bind-Value="_editingProvider.Temperature" Label="Temperature"
                                    Variant="Variant.Outlined" Min="0.0" Max="2.0" Step="0.1" Format="F1" />
                            </MudItem>
                        </MudGrid>
                    </MudStack>
                </MudCardContent>

                <MudCardActions Class="pa-4">
                    <MudSpacer />
                    <MudButton Variant="Variant.Text" OnClick="CancelEdit" Class="mr-2">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                        OnClick="SaveProviderAsync" Disabled="_savingProvider"
                        StartIcon="@Icons.Material.Filled.Save">
                        @if (_savingProvider) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Save
                    </MudButton>
                </MudCardActions>
            </MudCard>
        }
    </MudTabPanel>

    <MudTabPanel Text="General">
        <MudCard Elevation="0" Class="mt-4">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-2">Application Info</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Liuvis Studio v1.0 — AI-driven 3D Design Platform</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">.NET 10 + Blazor Server + MudBlazor</MudText>
            </MudCardContent>
        </MudCard>
    </MudTabPanel>

    <MudTabPanel Text="模型生成配置">
        <MudCard Elevation="0" Class="mt-4">
            <MudCardContent>
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:16px">
                    <MudText Typo="Typo.h6" Class="mb-0">Model Generation Settings</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                        @GetActiveGenModeDisplay()
                    </MudChip>
                </div>

                <MudStack Spacing="4">
                    <div>
                        <MudText Typo="Typo.subtitle2" Class="mb-2 mud-text-secondary">Generation Mode</MudText>
                        <MudToggleGroup @bind-Value="_genMode" T="string"
                            SelectionMode="SelectionMode.SingleSelection">
                            <MudToggleItem T="string" Value="@("llm")">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                                    <MudText>LLM Direct</MudText>
                                </MudStack>
                            </MudToggleItem>
                            <MudToggleItem T="string" Value="@("mcp")">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.IntegrationInstructions" Size="Size.Small" />
                                    <MudText>MCP Tool</MudText>
                                </MudStack>
                            </MudToggleItem>
                            <MudToggleItem T="string" Value="@("fake")">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.DataObject" Size="Size.Small" />
                                    <MudText>Fake Sample</MudText>
                                </MudStack>
                            </MudToggleItem>
                        </MudToggleGroup>
                    </div>

                    <MudDivider />

                    @if (_genMode == "mcp")
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2 mud-text-secondary">MCP Tool Configuration</MudText>
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_gen.McpServerUrl" Label="MCP Server URL"
                                    HelperText="e.g. http://localhost:8080" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="_gen.McpToolName" Label="Tool Name"
                                    HelperText="e.g. generate_model" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="_gen.McpApiKey" Label="API Key"
                                    HelperText="Optional" Variant="Variant.Outlined"
                                    InputType="@(_showMcpKey ? InputType.Text : InputType.Password)"
                                    Adornment="Adornment.End"
                                    AdornmentIcon="@(_showMcpKey ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                    OnAdornmentClick="() => _showMcpKey = !_showMcpKey" />
                            </MudItem>
                        </MudGrid>
                    }

                    @if (_genMode == "fake")
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2 mud-text-secondary">Fake Model Configuration</MudText>
                        <MudGrid Spacing="3">
                            <MudItem xs="6" md="4">
                                <MudSelect @bind-Value="_gen.FakeModelType" Label="Primitive Type"
                                    Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                                    <MudSelectItem Value="@("box")">Box</MudSelectItem>
                                    <MudSelectItem Value="@("sphere")">Sphere</MudSelectItem>
                                    <MudSelectItem Value="@("cylinder")">Cylinder</MudSelectItem>
                                    <MudSelectItem Value="@("capsule")">Capsule</MudSelectItem>
                                    <MudSelectItem Value="@("plane")">Plane</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="6" md="4">
                                <MudNumericField @bind-Value="_gen.FakeModelCount" Label="Model Count"
                                    Variant="Variant.Outlined" Min="1" Max="100" Step="1" />
                            </MudItem>
                        </MudGrid>
                    }

                    @if (_genMode == "llm")
                    {
                        <MudAlert Severity="Severity.Info" Class="mt-2">
                            Uses the active LLM provider from the <strong>LLM Configuration</strong> tab for model generation.
                        </MudAlert>
                    }
                </MudStack>
            </MudCardContent>

            <MudCardActions Class="pa-4">
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                    OnClick="SaveGenAsync" Disabled="_savingGen"
                    StartIcon="@Icons.Material.Filled.Save">
                    @if (_savingGen) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Save Configuration
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudTabPanel>

    <MudTabPanel Text="LLM Prompts">
        <MudCard Elevation="0" Class="mt-4">
            <MudCardContent>
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:16px">
                    <MudText Typo="Typo.h6">System Prompt Templates</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                        Editable
                    </MudChip>
                </div>

                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                    These prompts control how the LLM behaves. Use <code>{{context}}</code>, <code>{{input}}</code>,
                    or <code>{{description}}</code> as placeholders. Changes take effect on next request.
                </MudText>

                <MudStack Spacing="4">
                    <div>
                        <MudText Typo="Typo.subtitle2" Class="mb-2 mud-text-secondary">
                            Intent Classification Prompt
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-2">
                                NLU
                            </MudChip>
                        </MudText>
                        <MudTextField @bind-Value="_prompts.NluPrompt" Lines="12" Variant="Variant.Outlined"
                            HelperText="Classifies user intent. Placeholders: {{context}}, {{input}}" />
                    </div>

                    <MudDivider />

                    <div>
                        <MudText Typo="Typo.subtitle2" Class="mb-2 mud-text-secondary">
                            Query Response Prompt
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-2">
                                Query
                            </MudChip>
                        </MudText>
                        <MudTextField @bind-Value="_prompts.QueryPrompt" Lines="4" Variant="Variant.Outlined"
                            HelperText="System message when answering user questions" />
                    </div>

                    <MudDivider />

                    <div>
                        <MudText Typo="Typo.subtitle2" Class="mb-2 mud-text-secondary">
                            Unknown Intent Prompt
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-2">
                                Unknown
                            </MudChip>
                        </MudText>
                        <MudTextField @bind-Value="_prompts.UnknownPrompt" Lines="4" Variant="Variant.Outlined"
                            HelperText="System message when intent is unclear" />
                    </div>

                    <MudDivider />

                    <div>
                        <MudText Typo="Typo.subtitle2" Class="mb-2 mud-text-secondary">
                            3D Scene Generation Prompt
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-2">
                                Generation
                            </MudChip>
                        </MudText>
                        <MudTextField @bind-Value="_prompts.SceneGenerationPrompt" Lines="16" Variant="Variant.Outlined"
                            HelperText="Generates 3D scene JSON from description. Placeholder: {{description}}" />
                    </div>
                </MudStack>
            </MudCardContent>

            <MudCardActions Class="pa-4">
                <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                    OnClick="ResetPromptsAsync" Disabled="_savingPrompts"
                    StartIcon="@Icons.Material.Filled.Restore">
                    Reset to Defaults
                </MudButton>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                    OnClick="SavePromptsAsync" Disabled="_savingPrompts"
                    StartIcon="@Icons.Material.Filled.Save">
                    @if (_savingPrompts) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Save Prompts
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudTabPanel>

    <MudTabPanel Text="工具与技能">
        <MudCard Elevation="0" Class="mt-4">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-4">MCP Servers</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                    Configure Model Context Protocol servers for external tool integration.
                </MudText>

                @foreach (var server in _toolsSettings.McpServers)
                {
                    <div style="display:flex; align-items:center; gap:10px; padding:8px 12px; margin-bottom:8px; background:rgba(17,24,39,0.6); border:1px solid rgba(0,212,255,0.1); border-radius:6px">
                        <MudSwitch @bind-Value="server.IsEnabled" Color="Color.Primary" Size="Size.Small" />
                        <MudTextField @bind-Value="server.Name" Label="Name" Variant="Variant.Outlined" Dense="true" Style="flex:1; min-width:120px" />
                        <MudTextField @bind-Value="server.ServerUrl" Label="Server URL" Variant="Variant.Outlined" Dense="true" Style="flex:1.5; min-width:180px"
                                      Placeholder="http://localhost:8080" />
                        <MudTextField @bind-Value="server.Description" Label="Description" Variant="Variant.Outlined" Dense="true" Style="flex:1; min-width:100px" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => RemoveMcpServer(server))" Title="Remove" />
                    </div>
                }

                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           OnClick="AddMcpServer" StartIcon="@Icons.Material.Filled.Add">
                    Add MCP Server
                </MudButton>
            </MudCardContent>
        </MudCard>

        <MudCard Elevation="0" Class="mt-4">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-4">Skills</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                    Upload skill files (documents, prompts, reference data) to extend AI capabilities.
                </MudText>

                @foreach (var skill in _toolsSettings.Skills)
                {
                    <MudPaper Class="pa-4 mb-3" Style="background:rgba(17,24,39,0.6); border:1px solid rgba(0,212,255,0.1)">
                        <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px">
                            <MudSwitch @bind-Value="skill.IsEnabled" Color="Color.Primary" Size="Size.Small" />
                            <MudTextField @bind-Value="skill.Name" Label="Name" Variant="Variant.Outlined" Dense="true" Style="flex:1" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => RemoveSkill(skill))" Title="Remove" />
                        </div>
                        <MudTextField @bind-Value="skill.Description" Label="Description" Variant="Variant.Outlined" Dense="true" Class="mb-2" />
                        @if (!string.IsNullOrEmpty(skill.FileName))
                        {
                            <div style="display:flex; align-items:center; gap:8px; padding:8px 12px; background:rgba(0,212,255,0.05); border-radius:4px; margin-bottom:8px">
                                <MudIcon Icon="@Icons.Material.Filled.AttachFile" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.body2" Style="color:#e2e8f0; flex:1">@skill.FileName</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@(FormatFileSize(skill.FileSize))</MudText>
                            </div>
                        }
                        <label for="@($"skillFileInput-{skill.Id}")"
                               style="display:inline-flex; align-items:center; gap:6px; padding:4px 12px; border:1px solid rgba(0,212,255,0.5); border-radius:4px; color:#00d4ff; font-size:12px; cursor:pointer; pointer-events:auto">
                            <MudIcon Icon="@Icons.Material.Filled.Upload" Size="Size.Small" /> Upload File
                        </label>
                        <InputFile id="@($"skillFileInput-{skill.Id}")" OnChange="@((InputFileChangeEventArgs e) => HandleSkillFileUpload(skill, e))"
                                   style="display:none" />
                    </MudPaper>
                }

                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           OnClick="AddSkill" StartIcon="@Icons.Material.Filled.Add">
                    Add Skill
                </MudButton>
            </MudCardContent>
        </MudCard>

        <MudCardActions Class="pa-4">
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="SaveToolsAsync" Disabled="_savingTools"
                       StartIcon="@Icons.Material.Filled.Save">
                @if (_savingTools) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Save Configuration
            </MudButton>
        </MudCardActions>
    </MudTabPanel>
</MudTabs>

@code {
    private List<LlmProvider> _providers = new();
    private LlmProvider? _activeProvider;
    private bool _isLoading = true;
    private bool _isLoadingProviders = true;

    private LlmProvider _editingProvider = new() { Provider = "openai" };
    private bool _editDialogOpen;
    private bool _savingProvider;
    private bool _showEditApiKey;

    private GenerationSettings _gen = new();
    private string _genMode = "llm";
    private bool _savingGen;
    private bool _showMcpKey;

    private PromptSettings _prompts = new();
    private bool _savingPrompts;

    private ToolsSettings _toolsSettings = new();
    private bool _savingTools;
    private string _skillFileInput = "skillFileInput";

    protected override async Task OnInitializedAsync()
    {
        if (!RendererInfo.IsInteractive)
        {
            Logger.LogInformation("[Settings] Prerendering — rendering loading placeholder");
            return;
        }

        Logger.LogInformation("[Settings] Interactive mode — loading settings");
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _providers = await SettingsService.GetProvidersAsync();
            _activeProvider = _providers.FirstOrDefault(p => p.IsActive);
            _isLoadingProviders = false;

            _gen = await SettingsService.GetGenerationSettingsAsync();
            _genMode = _gen.Mode;

            _prompts = await SettingsService.GetPromptSettingsAsync();

            _toolsSettings = await SettingsService.GetToolsSettingsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[Settings] LoadDataAsync FAILED");
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // --- Provider CRUD ---

    private void AddProviderAsync()
    {
        _editingProvider = new LlmProvider { Provider = "openai", MaxTokens = 2000, Temperature = 0.3 };
        _editDialogOpen = true;
        _showEditApiKey = false;
    }

    private void EditProviderAsync(LlmProvider provider)
    {
        _editingProvider = new LlmProvider
        {
            Id = provider.Id,
            Name = provider.Name,
            Provider = provider.Provider,
            ApiKey = provider.ApiKey,
            BaseUrl = provider.BaseUrl,
            Model = provider.Model,
            OllamaUrl = provider.OllamaUrl,
            OllamaModel = provider.OllamaModel,
            MaxTokens = provider.MaxTokens,
            Temperature = provider.Temperature,
            IsActive = provider.IsActive
        };
        _editDialogOpen = true;
        _showEditApiKey = false;
    }

    private void CancelEdit()
    {
        _editDialogOpen = false;
    }

    private async Task SaveProviderAsync()
    {
        _savingProvider = true;
        try
        {
            if (_editingProvider.Id == 0)
                await SettingsService.AddProviderAsync(_editingProvider);
            else
                await SettingsService.UpdateProviderAsync(_editingProvider);

            _editDialogOpen = false;
            await LoadDataAsync();
        }
        finally
        {
            _savingProvider = false;
        }
    }

    private async Task DeleteProviderAsync(LlmProvider provider)
    {
        await SettingsService.DeleteProviderAsync(provider.Id);
        await LoadDataAsync();
    }

    private async Task ActivateProviderAsync(LlmProvider provider)
    {
        await SettingsService.ActivateProviderAsync(provider.Id);
        await LoadDataAsync();
    }

    // --- Generation settings ---

    private string GetActiveGenModeDisplay() => _genMode switch
