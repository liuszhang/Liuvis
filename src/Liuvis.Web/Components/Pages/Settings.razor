    // --- Tools & Skills ---

    private void AddMcpServer()
    {
        _toolsSettings.McpServers.Add(new McpServerConfig { Name = "New Server", IsEnabled = true });
    }

    private void RemoveMcpServer(McpServerConfig server)
    {
        _toolsSettings.McpServers.Remove(server);
    }

    private void AddSkill()
    {
        _toolsSettings.Skills.Add(new SkillConfig { Name = "New Skill", IsEnabled = true });
    }

    private void RemoveSkill(SkillConfig skill)
    {
        if (!string.IsNullOrEmpty(skill.FilePath))
        {
            _ = Storage.DeleteAsync(skill.FilePath);
        }
        _toolsSettings.Skills.Remove(skill);
    }

    private async Task HandleSkillFileUpload(SkillConfig skill, InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size == 0) return;

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var key = $"skills/{skill.Id}/{file.Name}";
            await Storage.UploadAsync(key, stream, file.ContentType);

            skill.FilePath = key;
            skill.FileName = file.Name;
            skill.FileSize = file.Size;

            if (string.IsNullOrWhiteSpace(skill.Name) || skill.Name == "New Skill")
                skill.Name = System.IO.Path.GetFileNameWithoutExtension(file.Name);

            Logger.LogInformation("[Settings] Skill file uploaded: {Name} ({Size} bytes)", file.Name, file.Size);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to upload skill file");
        }
    }

