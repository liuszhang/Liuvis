@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ISessionManager SessionManager
@inject ChatOrchestrationService ChatService
@inject IJSRuntime JS
@using Liuvis.Web.Components.Viewer

<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudText Typo="Typo.h4" Class="pa-4">Liuvis Design Studio</MudText>

<div style="display:flex; height:calc(100vh - 120px); background:#0a0e1a; color:#e2e8f0">
    @* --- Left Chat Panel --- *@
    <div style="width:400px; padding:24px; border-right:1px solid rgba(0,212,255,0.2); display:flex; flex-direction:column">
        <h3 style="color:#00d4ff; margin:0 0 16px 0">Design Assistant</h3>
        <input @bind="_chatInput" @bind:event="oninput"
            @onkeyup="HandleKeyUp"
            style="width:100%; padding:12px; background:#111827; border:1px solid rgba(0,212,255,0.3); color:#e2e8f0; border-radius:4px; font-size:14px"
            placeholder="Describe your 3D idea, e.g. Create a blue cube" />
        <button @onclick="SendChat" disabled="@_sending"
            style="margin-top:12px; padding:10px 24px; background:#00d4ff; color:#0a0e1a; border:none; border-radius:4px; cursor:pointer; font-weight:bold; font-size:14px">
            @if (_sending) { <span>@_progress</span> } else { <span>Send</span> }
        </button>
        <div style="margin-top:16px; flex:1; overflow-y:auto; font-size:13px">
            @if (!string.IsNullOrEmpty(_thinking))
            {
                <details open style="margin-bottom:12px">
                    <summary style="color:#7c3aed; cursor:pointer; font-weight:bold; margin-bottom:8px">Thinking Process</summary>
                    <pre style="color:#94a3b8; white-space:pre-wrap; font-family:'JetBrains Mono',monospace; font-size:12px; line-height:1.6; margin:0">@_thinking</pre>
                </details>
            }
            @foreach (var msg in _chatHistory)
            {
                <div style="margin-bottom:8px; padding:8px; border-radius:6px; background:@(msg.IsUser ? "rgba(0,212,255,0.1)" : "rgba(0,255,136,0.05)")">
                    <span style="font-weight:bold; color:@(msg.IsUser ? "#00d4ff" : "#00ff88")">@(msg.IsUser ? "You" : "AI"):</span>
                    <span style="color:#cbd5e1; margin-left:6px">@msg.Text</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(_response))
            {
                <div style="color:#00ff88; white-space:pre-wrap; padding:8px; border-radius:6px; background:rgba(0,255,136,0.05)">@_response</div>
            }
        </div>
    </div>

    @* --- Right Preview Panel --- *@
    <div style="flex:1; position:relative">
        <ModelViewer ModelUrl="@(_modelUrl ?? "")" SceneData="@_sceneData" />
    </div>
</div>

@code {
    private Guid _sessionId;
    private string _chatInput = "Create a blue cube";
    private string _response = "";
    private string _thinking = "";
    private string _progress = "Thinking...";
    private string? _modelUrl;
    private string? _sceneData;
    private bool _sending;
    private CancellationTokenSource? _cts;
    private List<ChatEntry> _chatHistory = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var session = await SessionManager.CreateSession("user-default");
            _sessionId = session.SessionId;
        }
        catch { _sessionId = Guid.NewGuid(); }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendChat();
    }

    private async Task SendChat()
    {
        if (string.IsNullOrWhiteSpace(_chatInput)) return;

        var message = _chatInput;
        _chatInput = "";
        _sending = true;
        _thinking = "";
        _response = "";
        _sceneData = null;
        _progress = "Thinking...";
        StateHasChanged();

        _cts?.Cancel();
        _cts = new CancellationTokenSource();

        try
        {
            _chatHistory.Add(new ChatEntry(message, true));

            var result = await ChatService.ProcessMessageAsync(
                _sessionId,
                message,
                onProgress: status =>
                {
                    _progress = status;
                    InvokeAsync(StateHasChanged);
                },
                cancellationToken: _cts.Token);

            _thinking = result.Thinking ?? "";
            _response = result.AssistantMessage;
            _chatHistory.Add(new ChatEntry(result.AssistantMessage, false));

            if (result.Type is "model_ready" or "model_updated" && result.ModelId.HasValue)
            {
                _modelUrl = $"/api/model/{result.ModelId}/download";

                if (result.Metadata != null && result.Metadata.TryGetValue("_scene", out var sceneVal))
                {
                    _sceneData = sceneVal switch
                    {
                        string s => s,
                        System.Text.Json.JsonElement je => je.GetString(),
                        _ => null
                    };
                }
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { _response = $"Error: {ex.Message}"; }
        finally
        {
            _sending = false;
            StateHasChanged();
        }
    }

    private record ChatEntry(string Text, bool IsUser);
}
