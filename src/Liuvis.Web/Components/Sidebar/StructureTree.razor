@using Liuvis.Web.Models

<div class="structure-tree pa-2">
    <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">Components</MudText>
    @foreach (var item in _treeItems)
    {
        <div class="tree-item pa-2" @onclick="() => OnNodeSelected.InvokeAsync(item.Value)" style="cursor: pointer;">
            <MudText Typo="Typo.body2">@item.Text</MudText>
        </div>
    }
</div>

@code {
    [Parameter] public List<ComponentVm> Components { get; set; } = new();
    [Parameter] public string? SelectedId { get; set; }
    [Parameter] public EventCallback<string> OnNodeSelected { get; set; }

    private List<TreeItemData> _treeItems = new();

    protected override void OnParametersSet()
    {
        _treeItems = Components.Select(c => new TreeItemData
        {
            Text = $"{c.Name} ({c.GeometryType})",
            Value = c.Id
        }).ToList();
    }

    public class TreeItemData
    {
        public string Text { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }
}
