@inject ChatOrchestrationService ChatService
@inject ISessionManager SessionManager
@inject NavigationManager Navigation

<MudCard Elevation="2" Class="chat-panel">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Design Assistant</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">Describe your 3D model idea</MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <ActionButtons SessionId="@SessionId" />
        </CardHeaderActions>
    </MudCardHeader>

    <MudCardContent Class="chat-messages pa-4">
        @foreach (var msg in _messages)
        {
            <MessageBubble Message="msg" />
        }

        @if (!string.IsNullOrEmpty(_statusText))
        {
            <div class="status-indicator">
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                <MudText Typo="Typo.caption" Class="mud-text-secondary ml-2">@_statusText</MudText>
            </div>
        }

        <div @ref="_scrollRef"></div>
    </MudCardContent>

    <MudCardActions Class="pa-3">
        <ChatInput OnSend="SendMessageAsync" IsDisabled="_isSending" />
    </MudCardActions>
</MudCard>

@code {
    [Parameter] public Guid SessionId { get; set; }
    [Parameter] public EventCallback<ModelReadyArgs> OnModelReady { get; set; }

    private List<ChatMessageVm> _messages = new();
    private bool _isSending;
    private string? _statusText;
    private ElementReference _scrollRef;

    protected override async Task OnInitializedAsync()
    {
        var session = await SessionManager.GetSession(SessionId);
        if (session?.Messages.Count > 0)
        {
            _messages = session.Messages.Select(m => new ChatMessageVm
            {
                Role = m.Role.ToString().ToLowerInvariant(),
                Content = m.Content,
                Timestamp = m.Timestamp
            }).ToList();
        }
    }

    private async Task SendMessageAsync(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return;
        _isSending = true;
        _statusText = null;

        _messages.Add(new ChatMessageVm { Role = "user", Content = text, Timestamp = DateTime.Now });
        StateHasChanged();

        try
        {
            var response = await ChatService.ProcessMessageAsync(
                SessionId,
                text,
                onProgress: status =>
                {
                    _statusText = status;
                    InvokeAsync(StateHasChanged);
                });

            _statusText = null;

            _messages.Add(new ChatMessageVm
            {
                Role = "assistant",
                Content = response.AssistantMessage,
                Timestamp = DateTime.Now,
                ModelId = response.ModelId,
                Type = response.Type,
                Thinking = response.Thinking
            });

            if (response.Type is "model_ready" or "model_updated" && OnModelReady.HasDelegate)
            {
                await OnModelReady.InvokeAsync(new ModelReadyArgs(
                    $"/storage/{response.ModelId}.glb",
                    new List<ComponentVm>()));
            }
        }
        catch (Exception ex)
        {
            _statusText = null;
            _messages.Add(new ChatMessageVm
            {
                Role = "assistant",
                Content = $"Error: {ex.Message}",
                Timestamp = DateTime.Now,
                IsError = true
            });
        }
        finally
        {
            _isSending = false;
            StateHasChanged();
        }
    }

    public class ChatMessageVm
    {
        public string Role { get; set; } = "user";
        public string Content { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; }
        public Guid? ModelId { get; set; }
        public string Type { get; set; } = "text";
        public bool IsError { get; set; }
        public string? Thinking { get; set; }
    }
}
