<MudTextField @bind-Value="_inputText" Label="Describe your design..." Variant="Variant.Outlined"
               Lines="2" Adornment="Adornment.End" AdornmentColor="Color.Primary"
               OnKeyDown="HandleKeyDown" Disabled="IsDisabled"
               AdornmentIcon="@Icons.Material.Filled.Send" OnAdornmentClick="SendAsync" />

@code {
    [Parameter] public EventCallback<string> OnSend { get; set; }
    [Parameter] public bool IsDisabled { get; set; }

    private string _inputText = string.Empty;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendAsync();
        }
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(_inputText) || IsDisabled) return;
        await OnSend.InvokeAsync(_inputText);
        _inputText = string.Empty;
    }
}
