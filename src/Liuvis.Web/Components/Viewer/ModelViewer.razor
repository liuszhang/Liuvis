@implements IAsyncDisposable
@inject IJSRuntime JS

<div id="@_jsContainerId" style="position:absolute;inset:0;background:#0a0e1a;
    background-image:linear-gradient(rgba(0,212,255,0.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,212,255,0.03) 1px,transparent 1px);
    background-size:40px 40px;overflow:hidden"></div>

@if (string.IsNullOrEmpty(ModelUrl) && string.IsNullOrEmpty(SceneData))
{
    <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:10;pointer-events:none;background:#0a0e1a">
        <MudIcon Icon="@Icons.Material.Filled.ViewInAr" Size="Size.Large" Color="Color.Secondary" />
        <MudText Typo="Typo.body1" Class="mud-text-secondary mt-4">3D Preview</MudText>
        <MudText Typo="Typo.caption">Click a model to preview</MudText>
    </div>
}

@code {
    [Parameter] public string? ModelUrl { get; set; }
    [Parameter] public string? SceneData { get; set; }

    private IJSObjectReference? _module;
    private bool _initialized;
    private string _jsContainerId = $"viewer-{Guid.NewGuid():N}";
    private string? _lastUrl;
    private string? _lastScene;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!RendererInfo.IsInteractive) return;

        if (firstRender && !_initialized)
        {
            try
            {
                _module = await JS.InvokeAsync<IJSObjectReference>("import", $"./js/three-module.js?v={DateTime.UtcNow.Ticks}");
                await _module.InvokeVoidAsync("initScene", _jsContainerId);
                _initialized = true;
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"[ModelViewer] Init FAILED: {ex}");
                return;
            }
        }

        if (!_initialized || _module == null) return;

        try
        {
            if (!string.IsNullOrEmpty(SceneData) && SceneData != _lastScene)
            {
                _lastScene = SceneData;
                _lastUrl = ModelUrl;
                Console.WriteLine("[ModelViewer] Building from scene JSON");
                await _module.InvokeVoidAsync("buildFromSceneDescription", SceneData);
            }
            else if (!string.IsNullOrEmpty(ModelUrl) && ModelUrl.StartsWith("/") && ModelUrl != _lastUrl)
            {
                _lastUrl = ModelUrl;
                _lastScene = null;
                Console.WriteLine($"[ModelViewer] Loading GLB: {ModelUrl}");
                await _module.InvokeVoidAsync("loadModel", ModelUrl, true);
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[ModelViewer] Load FAILED: {ex}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module != null)
        {
            try { await _module.DisposeAsync(); } catch { }
        }
    }
}
