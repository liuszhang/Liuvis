{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=liuvis_dev;Username=liuvis;Password=liuvis_dev"
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o",
    "EmbeddingModel": "text-embedding-3-small",
    "MaxTokens": 2000,
    "Temperature": 0.3
  },
  "Storage": {
    "Provider": "Local",
    "BasePath": "./data/models",
    "MinIO": {
      "Endpoint": "localhost:9000",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "BucketName": "liuvis-models",
      "UseSsl": false
    }
  },
  "Session": {
    "MaxContextRounds": 20,
    "SessionTimeoutMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
